      "text": "{\n\"name\" : \"Reja\",\n\"age: : 25,\n\"isStudent\" : True,\n\"subject\": [\"Computer Science\", \"math\",\"...\"],\n\"address\":\n            {\n                \"city\":\"Kolkata\",\n                \"ward\" : \"123B\",\n                \"pin\" :  \" 700013\"\n            }\n}",
      "fontSize": 16,
