      "seed": 1633552414,
      "version": 285,
      "versionNonce": 2075774786,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772207726348,
      "link": null,
      "locked": false,
      "text": "What is Firebase ? \nFirebase is a Backend-as-a-service platform developed by Google \n-> it provides ready- made backend services for mobile  and web applications \n    such as : Authentication , Realtime Database , cloude Storage , hosting etc...",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is Firebase ? \nFirebase is a Backend-as-a-service platform developed by Google \n-> it provides ready- made backend services for mobile  and web applications \n    such as : Authentication , Realtime Database , cloude Storage , hosting etc...",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DMQRvZVZ9iA77YLHxPgAv",
      "type": "text",
      "x": 256,
      "y": 2581.777821779251,
      "width": 402.5797119140625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 1516650114,
      "version": 68,
      "versionNonce": 934792962,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772207890881,
      "link": null,
      "locked": false,
      "text": "How Firebase Authentication carried out ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How Firebase Authentication carried out ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-mEyxsfJiFC7vRs1-MozW",
      "type": "text",
      "x": 265,
      "y": 2612.277821779251,
      "width": 482.94354248046875,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "au",
      "roundness": null,
      "seed": 1147876766,
      "version": 206,
      "versionNonce": 363433922,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772207888199,
      "link": null,
      "locked": false,
      "text": "Firebase Authentication allows users to sign in securely using:\n    1) Email & password\n    2) Phone number and OTP\n    3) Google sign-in\n    4) Facebook login\n    5) Anonymous user ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Firebase Authentication allows users to sign in securely using:\n    1) Email & password\n    2) Phone number and OTP\n    3) Google sign-in\n    4) Facebook login\n    5) Anonymous user ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oZDrwCgJWbmlw28slJ9sY",
      "type": "text",
      "x": 277,
      "y": 2754.1667125225067,
      "width": 48.895965576171875,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "av",
      "roundness": null,
      "seed": 1282189982,
      "version": 30,
      "versionNonce": 2019521026,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772207922606,
      "link": null,
      "locked": false,
      "text": "Steps:\n    ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Steps:\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "QKbiTAsSGfvLOHGEo8Npt",
      "type": "text",
      "x": 312,
      "y": 2781.1667125225067,
      "width": 488.5435791015625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aw",
      "roundness": null,
      "seed": 914774018,
      "version": 327,
      "versionNonce": 1611515806,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772208263301,
      "link": null,
      "locked": false,
      "text": "1.  user enters login credentials (username/password)\n2. App sends request to Firebase Authentication Server\n3) Firebase varifies credentials \n4) if varified -> Firebase returns a userId(UID) and ID Token\n5) app uses this token to access services securely  ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1.  user enters login credentials (username/password)\n2. App sends request to Firebase Authentication Server\n3) Firebase varifies credentials \n4) if varified -> Firebase returns a userId(UID) and ID Token\n5) app uses this token to access services securely  ",
      "autoResize": true,
      "lineHeight": 1.25
    },
