      "text": "Handles screen transitions and routing in Flutter apps.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Handles screen transitions and routing in Flutter apps.",
      "autoResize": true,
