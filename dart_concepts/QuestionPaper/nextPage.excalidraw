      "link": null,
      "locked": false,
      "text": "Firebase store data as Key-value pairs:\n        users(collection)\n            |-- user1 (document)\n                    |-- name : \"Reja\"\n                    |-- age   : \" 25,\n                    |__ city : \" Kolkata\"",
      "fontSize": 16,
