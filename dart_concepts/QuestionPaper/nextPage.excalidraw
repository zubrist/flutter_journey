    {
      "id": "0v1Fk9MB9haSV1dAKpqL6",
      "type": "text",
      "x": 301.16017150878906,
      "y": 6122.111020565033,
      "width": 678.87939453125,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1M",
      "roundness": null,
      "seed": 1661908387,
      "version": 123,
      "versionNonce": 1941336579,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772227459427,
      "link": null,
      "locked": false,
      "text": "Navigator is a Flutter widget used for managing navigation (routing) between screens.\nIt works like a stack (Last In First Out).\n\nWhen a new screen is opened → it is pushed onto the stack.\nWhen back is pressed → the top screen is popped.\n\nKey Methods:\n\n-> Navigator.push() → Opens new screen\n\n-> Navigator.pop() → Goes back\n\n-> Navigator.pushNamed() → Named route navigation",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Navigator is a Flutter widget used for managing navigation (routing) between screens.\nIt works like a stack (Last In First Out).\n\nWhen a new screen is opened → it is pushed onto the stack.\nWhen back is pressed → the top screen is popped.\n\nKey Methods:\n\n-> Navigator.push() → Opens new screen\n\n-> Navigator.pop() → Goes back\n\n-> Navigator.pushNamed() → Named route navigation",
      "autoResize": false,
      "lineHeight": 1.25
    },
