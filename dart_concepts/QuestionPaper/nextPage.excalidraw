    {
      "id": "XkN3RXl0Ck4w0Mdwd-veG",
      "type": "text",
      "x": 308,
      "y": 3505.5556013584137,
      "width": 576.0794677734375,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0E",
      "roundness": null,
      "seed": 850688926,
      "version": 108,
      "versionNonce": 1416071810,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772208754483,
      "link": null,
      "locked": false,
      "text": "Cloud firestore is a NoSQL, cloud-hosted database provided by Firebase. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cloud firestore is a NoSQL, cloud-hosted database provided by Firebase. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zhOmYxtVcEo2ELm5QxyIx",
      "type": "text",
      "x": 299,
      "y": 3540.3334019184113,
      "width": 650.04736328125,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0F",
      "roundness": null,
      "seed": 2133770690,
      "version": 130,
      "versionNonce": 921901442,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772208836348,
      "link": null,
      "locked": false,
      "text": "->  It stores data in documents and collections, and synchonizes data in real-time \n    accross web and mobile app.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "->  It stores data in documents and collections, and synchonizes data in real-time \n    accross web and mobile app.",
      "autoResize": true,
      "lineHeight": 1.25
    },
