    {
      "id": "oqfphZ0BPKlQc8eRr-7Xb",
      "type": "text",
      "x": 259,
      "y": 2474.277821779251,
      "width": 632.4474487304688,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
