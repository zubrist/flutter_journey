    },
    {
      "id": "bpvo9zcG-ossm8_mc4fsE",
      "type": "text",
      "x": 276.16017150878906,
      "y": 6660.499928474426,
      "width": 562.239501953125,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
      "roundness": null,
      "seed": 784412291,
      "version": 5,
      "versionNonce": 1577201635,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772227592390,
      "link": null,
      "locked": false,
      "text": "\n\nA StatelessWidget is a widget whose data cannot change once created.\n\nIt does not have a complex lifecycle like StatefulWidget.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\nA StatelessWidget is a widget whose data cannot change once created.\n\nIt does not have a complex lifecycle like StatefulWidget.",
      "autoResize": true,
      "lineHeight": 1.25
    },
